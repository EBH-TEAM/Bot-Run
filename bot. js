async function sendTelegramMessage(chatId, message) {
    try {
        const response = await axios.post(
            `https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage`,
            { chat_id: chatId, text: message, parse_mode: 'HTML' }
        );
        return response.data.ok;
    } catch (error) {
        console.error('মেসেজ পাঠাতে সমস্যা:', error.message);
        return false;
    }
}

async function registerTelegramUser(chatId, username, firstName) {
    const cleanUsername = (username || firstName || 'user_' + chatId).toString().toLowerCase().replace(/[^a-z0-9_]/g, '');
    try {
        const checkRes = await axios.get(`${FIREBASE_DB_URL}/telegramUsers/${cleanUsername}.json`);
        if (!checkRes.data) {
            await axios.put(`${FIREBASE_DB_URL}/telegramUsers/${cleanUsername}.json`, {
                chatId: chatId, username: cleanUsername, fullName: firstName || '',
                registeredAt: Date.now(), lastActive: Date.now()
            });
            console.log(`✅ নতুন নিবন্ধন: @${cleanUsername}`);
            return true;
        } else if (checkRes.data.chatId !== chatId) {
            await axios.patch(`${FIREBASE_DB_URL}/telegramUsers/${cleanUsername}.json`, { chatId: chatId, lastActive: Date.now() });
            console.log(`🔄 আপডেট: @${cleanUsername}`);
        } else {
            await axios.patch(`${FIREBASE_DB_URL}/telegramUsers/${cleanUsername}.json`, { lastActive: Date.now() });
        }
        return false;
    } catch (error) {
        console.error('রেজিস্টার করতে সমস্যা:', error.message);
        return false;
    }
}

async function checkTelegramUpdates() {
    try {
        let url = `https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/getUpdates`;
        if (lastUpdateId > 0) url += `?offset=${lastUpdateId + 1}`;
        const response = await axios.get(url);
        const data = response.data;
        if (data.ok && data.result && data.result.length > 0) {
            for (const update of data.result) {
                if (update.update_id > lastUpdateId) lastUpdateId = update.update_id;
                if (update.message && update.message.text === '/start') {
                    const chatId = update.message.chat.id;
                    const username = update.message.chat.username;
                    const firstName = update.message.chat.first_name;
                    console.log(`📨 /start পেয়েছি from ${chatId}`);
                    await registerTelegramUser(chatId, username, firstName);
                    const sent = await sendTelegramMessage(chatId, WELCOME_MESSAGE);
                    if (sent) console.log(`✅ ওয়েলকাম মেসেজ পাঠানো হয়েছে ${chatId} এ`);
                    else console.log(`❌ মেসেজ পাঠাতে ব্যর্থ`);
                }
            }
        }
    } catch (error) {
        console.error('আপডেট চেক করতে সমস্যা:', error.message);
    }
}

